# Rust
target/
# The Sluice engine spike (engine/) is its own set of detached cargo workspaces.
engine/**/target/
**/*.rs.bk
*.pdb

# Tauri build-generated schemas/artifacts (regenerated by tauri-build)
crates/sluice-ui/gen/

# Generated proto artifacts are emitted into OUT_DIR (under target/), never committed.

# Editor / OS cruft
.DS_Store
*.swp
.idea/
.vscode/

# Local environment overrides (never commit machine-specific config)
.env
.env.local

# Geo database is fetched per-machine (just geoip), never committed — only the NOTICE is tracked.
crates/sluice-ui/geoip/*.csv
crates/sluice-ui/geoip/*.mmdb
crates/sluice-ui/geoip/*.gz

# Internal AI/ops brief — local only, never published
CLAUDE.md

# Release artifacts (built by scripts/package-release.sh)
/dist/

# gh-audit reports — local only
/audits/
